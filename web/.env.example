VITE_API_BASE_URL=http://localhost/api

# Target del proxy del servidor de desarrollo Vite.
# Por defecto apunta al backend local (Docker override expone el puerto 8000).
# Para entorno de pruebas con IP remota, crear web/.env.local con:
#   VITE_PROXY_TARGET=http://<IP_DEL_HOST>:8000
VITE_PROXY_TARGET=http://localhost:8000
